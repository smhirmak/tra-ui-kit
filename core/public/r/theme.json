{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "theme",
  "type": "registry:style",
  "title": "MSI UI Theme",
  "description": "Complete theme configuration for MSI UI Kit including colors and design tokens",
  "cssVars": {
    "theme": {
      "font-sans": "Inter, sans-serif"
    },
    "dark": {
      "--border": "0 0% 14.9%",
      "--ring": "210 40% 98%",
      "--background": "222.2 84% 4.9%",
      "--foreground": "210 40% 98%",
      "--primary": "217.2 91.2% 59.8%",
      "--primary-soft": "224.3 76.3% 48%",
      "--primary-focused": "213 96.9% 87.1%",
      "--primary-foreground": "222.2 84% 4.9%",
      "--secondary": "217.2 32.6% 17.5%",
      "--secondary-foreground": "210 40% 98%",
      "--tetriary": "0 0% 98%",
      "--tetriary-foreground": "0 0% 9%",
      "--input": "217.2 32.6% 17.5%",
      "--input-fill": "222.2 84% 4.9%",
      "--neutral": "0 0% 98%",
      "--neutral-light": "0 0% 14.9%",
      "--neutral-white": "0 0% 9%",
      "--neutral-dark-white": "0 0% 14.9%",
      "--disabled": "0 0% 14.9%",
      "--disabled-dark": "0 0% 20%",
      "--disabled-light-dark": "0 0% 17%"
    }
  },
  "css": {
    "@theme inline": {
      "--color-border": "hsl(var(--border))",
      "--color-ring": "hsl(var(--ring))",
      "--color-foreground": "hsl(var(--foreground))",
      "--color-background": "hsl(var(--background))",
      "--color-primary": "hsl(var(--primary))",
      "--color-primary-soft": "hsl(var(--primary-soft))",
      "--color-primary-focused": "hsl(var(--primary-focused))",
      "--color-primary-foreground": "hsl(var(--primary-foreground))",
      "--color-primary-5": "hsl(var(--primary-5))",
      "--color-primary-15": "hsl(var(--primary-15))",
      "--color-primary-30": "hsl(var(--primary-30))",
      "--color-secondary": "hsl(var(--secondary))",
      "--color-secondary-foreground": "hsl(var(--secondary-foreground))",
      "--color-secondary-light": "hsl(var(--secondary-light))",
      "--color-tertiary": "hsl(var(--tetriary))",
      "--color-tertiary-foreground": "hsl(var(--tetriary-foreground))",
      "--color-error": "hsl(var(--error))",
      "--color-error-foreground": "hsl(var(--error-foreground))",
      "--color-error-light": "hsl(var(--error-light))",
      "--color-success": "hsl(var(--success))",
      "--color-success-light": "hsl(var(--success-light))",
      "--color-warning": "hsl(var(--warning))",
      "--color-warning-light": "hsl(var(--warning-light))",
      "--color-input": "hsl(var(--input))",
      "--color-input-hover": "hsl(var(--input-soft))",
      "--color-input-light": "hsl(var(--input-light))",
      "--color-input-focused": "hsl(var(--input-focused))",
      "--color-input-fill": "hsl(var(--input-fill))",
      "--color-neutral": "hsl(var(--neutral))",
      "--color-neutral-light": "hsl(var(--neutral-light))",
      "--color-neutral-black": "hsl(var(--neutral-black))",
      "--color-neutral-light-black": "hsl(var(--neutral-light-black))",
      "--color-neutral-grey": "hsl(var(--neutral-grey))",
      "--color-neutral-disabled-text": "hsl(var(--neutral-disabled-text))",
      "--color-neutral-white": "hsl(var(--neutral-white))",
      "--color-neutral-dark-white": "hsl(var(--neutral-dark-white))",
      "--color-disabled": "hsl(var(--disabled))",
      "--color-disabled-dark": "hsl(var(--disabled-dark))",
      "--color-disabled-light-dark": "hsl(var(--disabled-light-dark))",
      "--color-disabled-light": "hsl(var(--disabled-light))",
      "--color-button-disabled": "hsl(var(--button-disabled))",
      "--color-button-disabled-text": "hsl(var(--button-disabled-text))",
      "--color-button-text": "hsl(var(--button-text))"
    }
  }
}