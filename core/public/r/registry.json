          "neutral-black": "0 0% 12%",
          "neutral-light-black": "0 0% 25%",
          "neutral-grey": "0 0% 60%",
          "neutral-grey-soft": "hsla(0, 0%, 60%, 0.08)",
          "neutral-grey-hard": "hsl(0, 0%, 60%, 0.15)",
          "neutral": "0 0% 87%",
          "neutral-disabled-text": "223 12% 89%",
          "neutral-light": "225 14% 95%",
          "neutral-dark-white": "220 100% 99%",
          "neutral-white": "0 0% 100%",
          "button-disabled": "221 38% 95%",
          "button-disabled-text": "223 20% 75%",
          "button-text": "0 0% 100%",
          "input": "0 0% 87%",
          "input-light": "225 14% 95%",
          "input-fill": "0 0% 99%",
          "input-focused": "221 87% 52%, 0.3"
        },
        "dark": {
