          "text-body-s-regular--font-weight": "400",
          "text-body-xs-regular": "0.75rem",
          "text-body-xs-regular--line-height": "1.5",
          "text-body-xs-regular--font-weight": "400",
          "text-body-xxs-regular": "0.625rem",
          "text-body-xxs-regular--line-height": "1.4",
