      "text-body-medium": "1rem",
      "text-body-medium--line-height": "1.5",
      "text-body-medium--font-weight": "500",
      "text-body-s-medium": "0.875rem",
      "text-body-s-medium--line-height": "1.4",
      "text-body-s-medium--font-weight": "500",
      "text-body-xs-medium": "0.75rem",
