# Auto detect text files and normalize to LF in repository
* text=auto

# Force LF for common source and data files to avoid CRLF <-> LF churn
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Binary files (do not attempt normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
