{
  "name": "msi-ui-kit",
  "private": true,
  "version": "0.0.1",
  "description": "MSI UI Kit - React component library and CLI tooling",
  "scripts": {
    "prepare": "husky",
    "lint:cli": "cd cli && npx tsc --noEmit",
    "lint:core": "cd core && npx tsc --noEmit"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,json,css,md}": [
      "prettier --check"
    ],
    "cli/src/**/*.ts": [
      "bash -c 'cd cli && npx tsc --noEmit'"
    ],
    "core/registry/**/*.{ts,tsx}": [
      "bash -c 'cd core && npx tsc --noEmit'"
    ],
    "core/src/**/*.{ts,tsx}": [
      "bash -c 'cd core && npx tsc --noEmit'"
    ]
  }
}
